{
  "expo": {
    "name": "FamSync",
    "slug": "famsync",
    "scheme": "famsync",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker"
    ],
    "splash": {
      "backgroundColor": "#FFF9F1"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.saramah63.famsync",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF9F1"
      },
      "package": "com.saramah63.famsync"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "06eb9951-63ef-4185-8911-f2ebbcf15b11"
      }
    }
  }
}
